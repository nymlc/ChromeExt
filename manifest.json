{
  "manifest_version": 3,
  "name": "极客百宝箱",
  "version": "1.0.2",
  "description": "集成了多项实用工具的全能浏览器助手",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "commands": {
    "toggle-password": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "快速切换密码显示/隐藏"
    }
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png",
      "256": "icons/icon256.png",
      "512": "icons/icon512.png",
      "1024": "icons/icon1024.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png",
    "512": "icons/icon512.png",
    "1024": "icons/icon1024.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "shared/Toast.js",
        "shared/SideTooltip.js",
        "content/modules/BaseModule.js",
        "content/modules/PasswordHelper.js",
        "content/modules/CredentialFiller.js",
        "content/content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
